{
  "name": "@cs161/textbook",
  "version": "v0.0.0",
  "private": "true",
  "scripts": {
    "docs:build": "set NO_MKDOCS_2_WARNING=true&& set PYTHONWARNINGS=ignore::DeprecationWarning&& mkdocs build",
    "docs:serve": "set NO_MKDOCS_2_WARNING=true&& set PYTHONWARNINGS=ignore::DeprecationWarning&& python scripts/serve_mkdocs.py",
    "prettier": "prettier -w \"**/*.md\" \"**/*.html\"",
    "prettier:check": "prettier -c \"**/*.md\" \"**/*.html\""
  },
  "devDependencies": {
    "prettier": "^2.7.1"
  }
}
